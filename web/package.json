{
  "name": "@typst-collab/web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "build:typst-compiler": "cd .. && node scripts/prebuilt-typst-compiler.mjs build",
    "verify:typst-compiler": "cd .. && node scripts/prebuilt-typst-compiler.mjs verify",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:protocol": "npm --prefix ../protocol run check:types",
    "check:ai-excluded-build": "node scripts/check-ai-excluded-build.mjs",
    "generate:protocol": "npm --prefix ../protocol run generate:types",
    "lint": "oxlint src",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:i18n": "playwright test tests/e2e/i18n.spec.ts",
    "test:release-resilience": "node scripts/headless-release-resilience.mjs",
    "test:ai-agent-local": "node scripts/local-ai-agent-scenario.mjs",
    "sync:typst-docs": "node scripts/sync-typst-docs.mjs sync",
    "check:typst-docs": "node scripts/sync-typst-docs.mjs verify",
    "sync:typst-assets": "node scripts/sync-typst-assets.mjs",
    "sync:busytex-assets": "node scripts/sync-busytex-assets.mjs",
    "check:typst-runtime": "npm run sync:typst-assets && node scripts/check-typst-runtime.mjs",
    "dev": "npm run sync:typst-assets && npm run sync:busytex-assets && vite --host 127.0.0.1 --port 3000",
    "build": "npm run lint && npm run check:i18n && npm run check:protocol && npm run check:typst-docs && npm run sync:typst-assets && npm run sync:busytex-assets && tsc -b && vite build && node scripts/build-ai-runtime.mjs && node scripts/precompress-dist.mjs && npm run check:ai-excluded-build",
    "preview": "npm run sync:typst-assets && npm run sync:busytex-assets && vite preview --host 127.0.0.1 --port 3000"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@earendil-works/pi-agent-core": "0.80.7",
    "@earendil-works/pi-ai": "0.80.7",
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@lezer/highlight": "^1.2.3",
    "@myriaddreamin/typst-ts-renderer": "0.8.0-rc3",
    "@myriaddreamin/typst-ts-web-compiler": "file:../prebuilt/typst-compiler/package",
    "@myriaddreamin/typst.ts": "0.8.0-rc3",
    "@nvidia-elements/core": "2.0.4",
    "@nvidia-elements/styles": "2.0.2",
    "@nvidia-elements/themes": "2.0.0",
    "@tanstack/react-query": "^5.101.2",
    "@uiw/react-codemirror": "^4.25.11",
    "@xstate/react": "^6.1.0",
    "codemirror-lang-latex": "^0.4.1",
    "codemirror-lang-typst": "^0.4.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.24.0",
    "nanotar": "0.3.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "texlyre-busytex": "1.2.3",
    "typebox": "1.1.38",
    "xstate": "^5.32.4",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.73.0",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.10"
  }
}
